[Unit]
Description=PiWatch PWM fan controller
After=multi-user.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/piwatch
ExecStart=/opt/piwatch-venv/bin/python -m app.fan_controller --mode thermal --gpio 14 --frequency 100 --interval 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
